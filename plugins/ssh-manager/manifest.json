{
  "id": "ssh-manager",
  "name": "SSH Manager",
  "version": "1.0.0",
  "description": "Convenient SSH connection manager with password and session management.",
  "author": "NetTools",
  "icon": "icon.svg",
  "type": "protocol",
  "downloadUrl": "https://aurora-link-org.github.io/plugin-registry/plugins/ssh-manager/dist/plugin.wasm",
  "activation": {
    "engine": "wasm",
    "entry": "dist/plugin.wasm"
  },
  "contributes": {
    "protocols": [
      {
        "id": "ssh",
        "label": "SSH Connection",
        "settings": [
          {
            "id": "host",
            "label": "Host",
            "type": "string",
            "default": "127.0.0.1"
          },
          {
            "id": "port",
            "label": "Port",
            "type": "number",
            "default": 22
          },
          {
            "id": "username",
            "label": "Username",
            "type": "string",
            "default": "root"
          },
          {
            "id": "password",
            "label": "Password",
            "type": "password",
            "default": ""
          }
        ]
      }
    ]
  }
}
