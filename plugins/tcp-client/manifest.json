{
  "id": "tcp-client",
  "name": "TCP Client Protocol",
  "version": "1.0.0",
  "author": "Aurora Link",
  "description": "High-performance TCP Client",
  "type": "protocol",
  "activation": {
    "engine": "wasm",
    "entry": "plugin.wasm"
  },
  "contributes": {
    "protocols": [
      {
        "id": "tcp",
        "label": "TCP Client",
        "settings": [
          {
            "id": "host",
            "label": "Host IP",
            "type": "string",
            "default": "127.0.0.1"
          },
          {
            "id": "port",
            "label": "Port",
            "type": "number",
            "default": 8080
          }
        ]
      }
    ]
  }
}
